# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Auth
JWT_SECRET=your_jwt_secret_min_32_chars
# Apple Sign-In (optional)
APPLE_CLIENT_ID=com.example.app
APPLE_TEAM_ID=TEAMID123
APPLE_KEY_ID=KEYID123
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# LLM
WORKERS_AI_MODEL_TRIAL=@cf/meta/llama-3.1-8b-instruct
WORKERS_AI_MODEL_STANDARD=@cf/meta/llama-3.1-70b-instruct
WORKERS_AI_MODEL_PREMIUM=@cf/meta/llama-3.1-70b-instruct
# RAG Embeddings — bge-m3 is multilingual (Hebrew/French/English), bge-base-en-v1.5 is English-only
EMBEDDING_MODEL=@cf/baai/bge-m3
CLAUDE_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Sefaria
SEFARIA_BASE_URL=https://www.sefaria.org

# Brevo (emails)
BREVO_API_KEY=xkeysib-xxx
BREVO_SENDER_EMAIL=noreply@torahchat.app
BREVO_SENDER_NAME=Torah Chat

# App
APP_URL=http://localhost:5173
APP_NAME=Torah Chat

# Plans config
PLAN_FREE_TRIAL_DAYS=7
PLAN_STANDARD_QUESTIONS_LIMIT=500
PLAN_STANDARD_PRICE=9.99
PLAN_PREMIUM_PRICE=19.99

# Cache
SEFARIA_CACHE_TTL_SECONDS=86400

# Cron security (protège /api/cron/trial-reminders)
CRON_SECRET=your_cron_secret_min_32_chars

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# Admin dashboard (protège /admin)
ADMIN_SECRET=your_admin_secret_min_32_chars
